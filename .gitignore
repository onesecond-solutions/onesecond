# ─────────────────────────────────────────────────────────
# 원세컨드 .gitignore (2026-04-20 최종 통합본)
# Git으로 추적하지 않을 파일 목록
# 구버전 안전 규칙 + 신버전 확장 규칙 통합
# ─────────────────────────────────────────────────────────

# ── 환경 변수·비밀 키 (절대 커밋 금지) ────────────────────
.env
.env.local
.env.production
.env.development
.env.*.local
*.env
*.key
*.pem

# Supabase service_role key·민감 정보
**/secrets.js
**/secrets.json
secrets.json
**/*-secret.*
supabase-credentials.json
*_service_role*
supabase_secrets*

# ── 실제 사용자 데이터 (절대 커밋 금지) ───────────────────
exports/
user_data/
backups/
real_users.csv
actual_*.csv

# ── 보험사 라이센스 위험 자료 (절대 커밋 금지) ─────────────
sosiggi/

# ── OS 생성 파일 ──────────────────────────────────────────
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
.fseventsd

# Linux
*~
.directory
.Trash-*

# ── 에디터·IDE 설정 ───────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── 로그·임시 파일 ────────────────────────────────────────
*.log
*.tmp
*.temp
*.bak
*.swp
*.swo
logs/
tmp/
.cache/

# ── Node.js (Claude Code 설치 시 생성) ───────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ── Python (혹시 사용 시) ────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
venv/
.venv/

# ── 빌드·배포 산출물 ──────────────────────────────────────
dist/
build/
out/

# ── 테스트 산출물 ─────────────────────────────────────────
test-output/
test-results/
coverage/

# ── 대용량 미디어 (GitHub Pages 용량 관리) ───────────────
# 원본 영상·고해상도 이미지는 별도 관리
*.mov
*.mp4
*.psd
*.ai

# ── 압축 파일 ─────────────────────────────────────────────
*.zip
*.tar.gz
*.rar
*.7z

# ── Claude Code 전용 (인증·로컬 설정) ────────────────────
.claude/*
!.claude/commands/
!.claude/settings.json
!.claude/hooks/
!.claude/skills/
# settings.local.json = 본인 PC 개별 permissions allow (차단 유지)
CLAUDE.md.local

# ── Claude Code 작업 임시물 (지시서·맥락은 유지) ─────────
claude_code/_tmp/
claude_code/_scratch/

# ── 개인 메모 (로컬 전용) ─────────────────────────────────
NOTES.md
TODO.md
SCRATCH.md
_private/

# ── 워킹트리 잡파일 재발 방지 (2026-06-06 정리) ──────────────
# newsletters 분할 시드 조각 (적재 후 불필요, 보관은 리포 밖 _onesecond_attic)
db/newsletters/461_seg*.sql

# 소식지 원본 묶음 — 리포 밖 보관 원칙(C:\limtaesung\newsletter_2026_06). 혹시 복사돼도 추적 금지 (2026-06-08)
newsletter_2026_06/
**/*소식지 모음*/
# 미사용 홈 배너 후보 이미지 (org01~03/stars/emoji 는 추적 유지 — 이 패턴은 home_banner_ prefix만)
assets/images/home_banner/home_banner_*.jpg
# 세션 로컬 복구 폴더 (.LOCAL 작업물)
.session_recovery_*/
# 카톡 마이그레이션 원본 (PII 가능성 — Public 리포 커밋 사고 봉쇄. 이동/처분은 별도 결재)
work folder/
# 2026-05-21 대업그레이드 산출물·스크린샷 (대용량. 이동/처분은 별도 결재)
upgrade_20260521/

# ─────────────────────────────────────────────────────────
# ── 허용 예외 (명시적 추적) ───────────────────────────────
# 위 규칙에도 불구하고 아래 항목은 Git이 추적함
# ─────────────────────────────────────────────────────────
!.gitignore
!README.md
!claude_code/**

# ── 예외의 예외: Supabase 백업 덤프 (민감 정보 가능성 + 누적 용량) ──
claude_code/_docs/supabase_dumps/backup_*/

# CRON_SECRET 로테이션 임시 파일 (로컬 전용, 로테이션 후 삭제)
.cron_secret_new.txt
.supabase_pat.txt
